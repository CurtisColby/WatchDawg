# =============================================================
# WatchDawg Backend — Environment Configuration
# =============================================================
# COPY this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================

# --- Core Application ---
APP_PORT=6767
APP_ENV=development
# Set to a strong random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET

# --- Encryption (ChartHound Standard) ---
# Fernet key for encrypting sensitive data at rest in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_REAL_KEY

# --- Database ---
# Path inside the container. The /app/data directory is volume-mounted for persistence.
DATABASE_URL=sqlite+aiosqlite:///app/data/watchdawg.db

# --- yt-dlp / Cookie Authentication ---
# Path to Netscape-format cookies.txt inside the container (mounted read-only).
YTDLP_COOKIES_PATH=/config/cookies.txt

# --- Reddit Scraping ---
# Comma-separated list of subreddits to scrape (no r/ prefix)
REDDIT_SUBREDDITS=SexyMusicVideos
# Scrape interval in minutes
SCRAPE_INTERVAL_MINUTES=30

# --- Download / Archiving ---
# Path inside the container where favorited videos are saved.
MUSIC_VIDEOS_PATH=/music_videos

# --- Timezone ---
TIMEZONE=America/Chicago
